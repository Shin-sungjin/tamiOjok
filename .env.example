# PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=ecommerce

# JWT
JWT_SECRET=

# OAuth2 - Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# OAuth2 - Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OAuth2 - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS: 프론트엔드가 서빙되는 origin (nginx 컨테이너 기준으로는 Cloudflare Tunnel URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# 프론트엔드 빌드 시점에 baked-in 되는 백엔드 API 주소
VITE_API_BASE_URL=http://localhost:8080

# Cloudflare Named Tunnel 토큰 (4-2단계, 도메인 확보 후에만 필요. Quick Tunnel 사용 중이면 비워둠)
CLOUDFLARE_TUNNEL_TOKEN=
